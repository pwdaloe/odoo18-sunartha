<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ==================== GROUPS ==================== -->
        <record id="group_account_user" model="res.groups">
            <field name="name">Pengguna Akuntansi Sunartha</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
        </record>

        <record id="group_account_approver" model="res.groups">
            <field name="name">Approver Jurnal Sunartha</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="implied_ids" eval="[(4, ref('sunartha_account_base.group_account_user'))]"/>
        </record>

        <record id="group_account_manager" model="res.groups">
            <field name="name">Manager Akuntansi Sunartha</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="implied_ids" eval="[(4, ref('sunartha_account_base.group_account_approver'))]"/>
        </record>

        <!-- ==================== RECORD RULES ==================== -->
        <!-- Approval request: hanya bisa dilihat oleh requester, approver, atau manager -->
        <record id="rule_approval_request_user" model="ir.rule">
            <field name="name">Approval Request: akses pengguna sendiri</field>
            <field name="model_id" ref="model_sunartha_account_approval_request"/>
            <field name="domain_force">[
                '|', '|',
                ('requester_id', '=', user.id),
                ('approver_id', '=', user.id),
                ('move_id.company_id', 'in', company_ids)
            ]</field>
            <field name="groups" eval="[(4, ref('sunartha_account_base.group_account_user'))]"/>
        </record>

        <record id="rule_approval_request_manager" model="ir.rule">
            <field name="name">Approval Request: akses manager penuh</field>
            <field name="model_id" ref="model_sunartha_account_approval_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('sunartha_account_base.group_account_manager'))]"/>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_sunartha_recurring_journal" model="ir.cron">
            <field name="name">Sunartha: Generate Recurring Journals</field>
            <field name="model_id" search="[('model', '=', 'sunartha.recurring.journal')]"/>
            <field name="state">code</field>
            <field name="code">model._cron_generate_recurring()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>

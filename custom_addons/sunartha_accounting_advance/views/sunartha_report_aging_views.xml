<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===== FORM VIEW ===== -->
    <record id="view_report_aging_form" model="ir.ui.view">
        <field name="name">sunartha.report.aging.form</field>
        <field name="model">sunartha.report.aging</field>
        <field name="arch" type="xml">
            <form string="Aging Report">
                <header>
                    <button name="action_generate" string="Generate Report"
                            type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="partner_type" widget="badge"
                                   decoration-warning="partner_type == 'receivable'"
                                   decoration-info="partner_type == 'payable'"
                                   readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Parameter">
                            <field name="partner_type"/>
                            <field name="as_of_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Filter">
                            <field name="branch_id"/>
                            <field name="ledger_id"/>
                        </group>
                    </group>
                    <separator string="Aging Detail"/>
                    <field name="line_ids" readonly="1" nolabel="1">
                        <list>
                            <field name="partner_name" string="Partner"/>
                            <field name="account_name" string="Account" optional="show"/>
                            <field name="bucket_current" string="Current (Belum Jatuh Tempo)"/>
                            <field name="bucket_1_30" string="1-30 Hari"/>
                            <field name="bucket_31_60" string="31-60 Hari"/>
                            <field name="bucket_61_90" string="61-90 Hari"/>
                            <field name="bucket_91_120" string="91-120 Hari"/>
                            <field name="bucket_over_120" string="&gt;120 Hari"/>
                            <field name="total" string="Total" sum="Grand Total"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ===== ACTIONS ===== -->
    <record id="action_report_ar_aging" model="ir.actions.act_window">
        <field name="name">AR Aging</field>
        <field name="res_model">sunartha.report.aging</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'default_partner_type': 'receivable'}</field>
    </record>

    <record id="action_report_ap_aging" model="ir.actions.act_window">
        <field name="name">AP Aging</field>
        <field name="res_model">sunartha.report.aging</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'default_partner_type': 'payable'}</field>
    </record>

</odoo>

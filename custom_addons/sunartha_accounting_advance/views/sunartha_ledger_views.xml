<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sunartha_ledger_list" model="ir.ui.view">
        <field name="name">sunartha.ledger.list</field>
        <field name="model">sunartha.ledger</field>
        <field name="arch" type="xml">
            <list string="Ledger">
                <field name="code"/>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_sunartha_ledger_form" model="ir.ui.view">
        <field name="name">sunartha.ledger.form</field>
        <field name="model">sunartha.ledger</field>
        <field name="arch" type="xml">
            <form string="Ledger">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sunartha_ledger" model="ir.actions.act_window">
        <field name="name">Ledger</field>
        <field name="res_model">sunartha.ledger</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

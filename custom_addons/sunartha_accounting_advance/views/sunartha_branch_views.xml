<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sunartha_branch_list" model="ir.ui.view">
        <field name="name">sunartha.branch.list</field>
        <field name="model">sunartha.branch</field>
        <field name="arch" type="xml">
            <list string="Branch">
                <field name="code"/>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_sunartha_branch_form" model="ir.ui.view">
        <field name="name">sunartha.branch.form</field>
        <field name="model">sunartha.branch</field>
        <field name="arch" type="xml">
            <form string="Branch">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sunartha_branch" model="ir.actions.act_window">
        <field name="name">Branch</field>
        <field name="res_model">sunartha.branch</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
